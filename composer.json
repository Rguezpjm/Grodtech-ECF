{
    "name": "grodtech/ecf-php",
    "description": "SDK PHP oficial para integrar aplicaciones con la pasarela ECF GRODTECH (facturación electrónica DGII República Dominicana). Soporta envío de comprobantes en JSON o XML, conversión y firma server-side.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ecf",
        "dgii",
        "factura-electronica",
        "facturacion-electronica",
        "republica-dominicana",
        "comprobante-fiscal-electronico",
        "encf",
        "sdk",
        "xml",
        "grodtech"
    ],
    "homepage": "https://ecf.grodtech.com",
    "readme": "README.md",
    "support": {
        "docs": "https://ecf.grodtech.com/docs",
        "issues": "https://github.com/Rguezpjm/Grodtech-ECF/issues",
        "source": "https://github.com/Rguezpjm/Grodtech-ECF",
        "email": "contacto@grodtech.com",
        "security": "https://ecf.grodtech.com/contact"
    },
    "authors": [
        {
            "name": "GRODTECH",
            "homepage": "https://ecf.grodtech.com",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-dom": "*",
        "ext-simplexml": "*",
        "ext-libxml": "*"
    },
    "suggest": {
        "ext-zip": "Requerido si manejas certificados o archivos comprimidos.",
        "ext-mbstring": "Mejor soporte para caracteres UTF-8 y strings multibyte."
    },
    "autoload": {
        "psr-4": {
            "Grodtech\\Ecf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Grodtech\\Ecf\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
